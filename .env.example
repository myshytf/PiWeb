# pi-web runtime configuration
PI_WEB_PORT=9876
PI_WEB_HOST=0.0.0.0
# PI_WEB_CWD=/path/to/your/project
# PI_WEB_AGENT_DIR=/Users/you/.pi/agent

# Authentication
PI_WEB_USERNAME=piweb
# Leave unset to generate ~/.pi/agent/pi-web-credentials.json on first run.
# PI_WEB_PASSWORD=replace-with-a-long-random-password
# PI_WEB_NO_AUTH=0
# PI_WEB_CREDENTIALS_FILE=/Users/you/.pi/agent/pi-web-credentials.json

# Optional security controls
# Comma-separated same-origin exceptions for API CORS.
# PI_WEB_ALLOWED_ORIGINS=https://pi-web.example.com
# Restrict file browser/write APIs to specific roots.
# PI_WEB_ALLOWED_ROOTS=/Users/you/projects,/Users/you/.pi
# Trust reverse-proxy client IP headers for auth rate limiting.
# PI_WEB_TRUST_PROXY=1
# Force Secure on the auth cookie when served behind HTTPS.
# PI_WEB_COOKIE_SECURE=1

# Push notifications
# Use a URL or mailto: address that identifies your app/operator.
PI_WEB_VAPID_SUBJECT=mailto:you@example.com
